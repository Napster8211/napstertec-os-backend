generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  // The url line has been completely removed
}

// --- ENUMS: Enforcing Strict System States ---
enum SystemRole {
  EXECUTIVE_TECHNICAL_DIRECTOR
  BUSINESS_DEVELOPMENT
  MARKETING
  ENGINEER
  CLIENT
}

enum LeadStatus {
  NEW_LEAD
  CONTACTED
  DEMO_SCHEDULED
  PROPOSAL_SENT
  NEGOTIATION
  CLOSED_WON
  REJECTED
}

enum ProjectStatus {
  PLANNING
  DEVELOPMENT
  TESTING
  DEPLOYED
  MAINTENANCE
}

enum InvoiceStatus {
  PENDING
  PAID
  OVERDUE
}

enum MilestoneStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
}

// --- MODELS ---

model User {
  id             String     @id @default(uuid())
  email          String     @unique
  passwordHash   String
  fullName       String
  role           SystemRole @default(ENGINEER)
  
  // RBAC Array: Granular system permissions stored as strings
  permissions    String[]   
  
  profileImage   String?
  bio            String?    @db.Text
  isActive       Boolean    @default(true)
  
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  // Relations
  assignedLeads  Lead[]
  projects       Project[]  @relation("ProjectTeam")
  tickets        Ticket[]
  auditLogs      AuditLog[]
  
  // New Enterprise Portal Relations
  activities     Activity[]
  uploadedDocs   Document[]
  messages       Message[]
}

model Lead {
  id             String     @id @default(uuid())
  companyName    String
  contactPerson  String
  email          String
  phone          String?
  status         LeadStatus @default(NEW_LEAD)
  
  meetingNotes   String?    @db.Text
  proposalLink   String?
  nextFollowUp   DateTime?
  
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  // Assigned Team Member
  assignedToId   String?
  assignedTo     User?      @relation(fields: [assignedToId], references: [id])
  
  // THE BRIDGE: Connects a won lead to its active project
  project        Project?
}

model Project {
  id             String        @id @default(uuid())
  title          String
  description    String        @db.Text
  status         ProjectStatus @default(PLANNING)
  progress       Int           @default(0) // Master percentage tracking (0-100)
  repoUrl        String?
  deploymentUrl  String?
  deadline       DateTime?
  
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  // THE BRIDGE: Link back to the CRM Lead
  leadId         String?       @unique
  lead           Lead?         @relation(fields: [leadId], references: [id])

  // Relations
  team           User[]        @relation("ProjectTeam")
  tickets        Ticket[]
  
  // New Enterprise Portal Relations
  activities     Activity[]
  documents      Document[]
  invoices       Invoice[]
  messages       Message[]
  milestones     Milestone[]
}

model Milestone {
  id          String          @id @default(uuid())
  title       String
  status      MilestoneStatus @default(PENDING)
  dueDate     DateTime?
  completedAt DateTime?
  
  projectId   String
  project     Project         @relation(fields: [projectId], references: [id])
  
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
}

model Activity {
  id          String   @id @default(uuid())
  title       String
  description String   @db.Text
  timestamp   DateTime @default(now())
  
  projectId   String
  project     Project  @relation(fields: [projectId], references: [id])
  
  userId      String?
  user        User?    @relation(fields: [userId], references: [id])
}

model Document {
  id          String   @id @default(uuid())
  fileName    String
  fileUrl     String   // Secure link to AWS S3 / Supabase Storage
  fileType    String   // e.g., "PDF", "DOCX", "IMAGE"
  
  projectId   String
  project     Project  @relation(fields: [projectId], references: [id])
  
  uploadedById String
  uploadedBy  User     @relation(fields: [uploadedById], references: [id])
  
  createdAt   DateTime @default(now())
}

model Invoice {
  id            String        @id @default(uuid())
  invoiceNumber String        @unique
  amount        Float
  status        InvoiceStatus @default(PENDING)
  issueDate     DateTime      @default(now())
  dueDate       DateTime
  pdfUrl        String?
  
  projectId     String
  project       Project       @relation(fields: [projectId], references: [id])
  
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
}

model Message {
  id            String   @id @default(uuid())
  content       String   @db.Text
  isRead        Boolean  @default(false)
  attachmentUrl String?
  
  projectId     String
  project       Project  @relation(fields: [projectId], references: [id])
  
  senderId      String
  sender        User     @relation(fields: [senderId], references: [id])
  
  createdAt     DateTime @default(now())
}

model AuditLog {
  id          String   @id @default(uuid())
  action      String   // e.g., "DEPLOY_PROJECT", "DELETE_LEAD"
  metadata    Json?    // Stores IP, device info, or changed data payload
  timestamp   DateTime @default(now())

  // Who performed the action
  userId      String?
  user        User?    @relation(fields: [userId], references: [id])
}

model Ticket {
  id          String   @id @default(uuid())
  subject     String
  description String   @db.Text
  status      String   @default("OPEN") // OPEN, IN_PROGRESS, RESOLVED
  priority    String   @default("NORMAL") // LOW, NORMAL, URGENT

  // Link back to the Client who submitted it
  clientId    String
  client      User     @relation(fields: [clientId], references: [id])

  // Link to the specific Project having the issue
  projectId   String
  project     Project  @relation(fields: [projectId], references: [id])

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}